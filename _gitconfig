[credential]
	helper = !aws --profile work codecommit credential-helper $@
	UseHttpPath = true
[user]
	name = Brett Dargan
	email = brett.dargan@gmail.com
[core]
	excludesfile = /Users/brett.dargan/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[alias]
	ahead = log origin/master..HEAD --oneline
